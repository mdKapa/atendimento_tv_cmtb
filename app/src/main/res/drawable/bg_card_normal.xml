<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- Retorno aos tons cinza "espelhados" com gradiente (como o IPMA antigo) -->
    <gradient
        android:startColor="#1AFFFFFF"
        android:centerColor="#0AFFFFFF"
        android:endColor="#03FFFFFF"
        android:angle="135" />

    <!-- Outline fino e subtil -->
    <stroke
        android:width="1dp"
        android:color="#1AFFFFFF" />

    <corners android:radius="12dp" />
</shape>