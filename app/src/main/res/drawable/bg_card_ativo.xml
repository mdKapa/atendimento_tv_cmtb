<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- Azul Primário mantido. O ângulo 270º (Cima para Baixo) com o escuro no topo
         cria a sombra interna, simulando o efeito pressionado/fundo. -->
    <gradient
        android:startColor="#0D2A54"
        android:endColor="#1D4ED8"
        android:angle="270" />

    <stroke
        android:width="1.5dp"
        android:color="#3B82F6" />

    <corners android:radius="12dp" />
</shape>