<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/itemDocumentoRoot"
    android:layout_width="140dp"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:padding="10dp"
    android:layout_margin="3dp"
    android:background="@drawable/bg_card_normal">

    <ImageView
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:src="@android:drawable/ic_menu_report_image"
        android:tint="@color/texto_inativo"
        android:contentDescription="Documento" />

    <View android:layout_width="1dp" android:layout_height="8dp" />

    <TextView
        android:id="@+id/tvTituloDocumento"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:textColor="@color/texto_inativo"
        android:textSize="11sp"
        android:maxLines="3"
        android:ellipsize="end"
        android:lineSpacingMultiplier="1.2" />

    <View android:layout_width="1dp" android:layout_height="4dp" />

    <TextView
        android:id="@+id/tvDataDocumento"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:textColor="@color/texto_inativo"
        android:textSize="10sp"
        android:maxLines="1"
        android:ellipsize="end" />

</LinearLayout>