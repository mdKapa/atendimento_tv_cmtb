<?xml version="1.0" encoding="utf-8"?>
<!-- Componente otimizado: Separador interno removido. Textos consistentes com ALL CAPS -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <!-- Cabeçalho do Dia (IDÊNTICO à Previsão Local: CAPS, 12sp, negrito suave) -->
    <TextView
        android:id="@+id/tvTituloDia"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/texto_inativo"
        android:textSize="12sp"
        android:textStyle="bold"
        android:textAllCaps="true"
        android:letterSpacing="0.05"
        android:layout_marginBottom="6dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:baselineAligned="false">

        <!-- Bloco Esquerdo: Estado do Tempo (50% de largura) -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/imgTempoIcon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_camera"
                android:contentDescription="@string/desc_estado_tempo"
                app:tint="@color/texto_secundario"
                xmlns:app="http://schemas.android.com/apk/res-auto" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="6dp">

                <TextView
                    android:id="@+id/tvTempoDescricao"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/ipma_a_carregar"
                    android:textColor="@color/texto_primario"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/tvTempoMinMax"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="-- | --"
                    android:textColor="@color/texto_inativo"
                    android:textSize="9sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Bloco Direito: Risco de Incêndio (50% de largura) - SEM DIVISÓRIA VERTICAL -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginStart="8dp">

            <ImageView
                android:id="@+id/imgRiscoIncendio"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@android:drawable/ic_dialog_alert"
                android:contentDescription="@string/desc_risco_incendio" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="6dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/ipma_risco_incendio_pir"
                    android:textColor="@color/texto_inativo"
                    android:textSize="8sp"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/tvRiscoNivel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/ipma_a_carregar"
                    android:textColor="@color/risco_reduzido"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>