<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/itemCategoriaRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingStart="10dp"
    android:paddingEnd="10dp"
    android:paddingTop="6dp"
    android:paddingBottom="6dp"
    android:background="@color/bg_card">

    <!-- Ícone com fundo próprio -->
    <FrameLayout
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:background="@color/cat_icone_bg">

        <ImageView
            android:id="@+id/imgCategoria"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_gravity="center"
            android:src="@android:drawable/ic_menu_agenda"
            android:contentDescription="Ícone" />
    </FrameLayout>

    <View android:layout_width="8dp" android:layout_height="1dp" />

    <TextView
        android:id="@+id/tvNomeCategoria"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:textColor="@color/texto_inativo"
        android:textSize="12sp"
        android:maxLines="2"
        android:ellipsize="end"
        android:lineSpacingMultiplier="1.15" />

</LinearLayout>