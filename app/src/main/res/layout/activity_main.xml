<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_principal"
    android:keepScreenOn="true">

    <!-- ===================================================== -->
    <!-- TOPO (weight 1) — Logo + Relógio                      -->
    <!-- ===================================================== -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:background="@color/bg_principal">

        <!-- Logo -->
        <ImageView
            android:id="@+id/imgLogo"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:adjustViewBounds="true"
            android:scaleType="fitStart"
            android:src="@drawable/ic_logo_mtbr_rect"
            android:contentDescription="Logótipo" />

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <!-- Relógio + Data -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="end">

            <TextView
                android:id="@+id/tvHora"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00:00"
                android:textColor="@color/texto_primario"
                android:textSize="32sp"
                android:textStyle="bold"
                android:lineSpacingMultiplier="1.0" />

            <TextView
                android:id="@+id/tvData"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Segunda-feira, 1 de Janeiro de 2026"
                android:textColor="@color/texto_inativo"
                android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Separador invisível -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider" />

    <!-- ===================================================== -->
    <!-- CORPO (weight 9)                                      -->
    <!-- ===================================================== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="9"
        android:orientation="horizontal">

        <!-- ============================================= -->
        <!-- COLUNA ESQUERDA 52%                           -->
        <!-- ============================================= -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="52"
            android:orientation="vertical"
            android:padding="10dp">

            <!-- Vídeo (weight 5 — ~52% da coluna) -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="6"
                android:background="@drawable/bg_video_radius"
                android:clipToOutline="true">

                <androidx.media3.ui.PlayerView
                    android:id="@+id/playerView"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    app:use_controller="false"
                    app:resize_mode="zoom" />

                <!-- Badge AO VIVO -->
                <TextView
                    android:id="@+id/tvLiveBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="top|end"
                    android:layout_margin="12dp"
                    android:text="● AO VIVO"
                    android:textColor="@color/texto_primario"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_badge_live"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp" />
            </FrameLayout>

            <View android:layout_width="match_parent" android:layout_height="12dp" />

            <!-- Bloco IPMA -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="84dp"
                android:orientation="horizontal"
                android:baselineAligned="false"
                android:weightSum="2">

                <!-- Metade esquerda: Risco de Incêndio -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_ipma_card"
                    android:clipToOutline="true"
                    android:paddingStart="12dp"
                    android:paddingEnd="8dp"
                    android:layout_marginEnd="6dp">

                    <ImageView
                        android:id="@+id/imgRiscoIncendio"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@android:drawable/ic_dialog_alert"
                        android:contentDescription="Risco de Incêndio" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:paddingStart="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="RISCO DE INCÊNDIO"
                            android:textColor="@color/texto_inativo"
                            android:textSize="8sp"
                            android:letterSpacing="0.08" />

                        <TextView
                            android:id="@+id/tvRiscoNivel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="A carregar..."
                            android:textColor="@color/risco_reduzido"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvRiscoLocal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Terras de Bouro"
                            android:textColor="@color/texto_inativo"
                            android:textSize="9sp"
                            android:maxLines="1"
                            android:ellipsize="end" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Metade direita: Placeholder previsão -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:background="@drawable/bg_ipma_card"
                    android:clipToOutline="true"
                    android:layout_marginStart="6dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PREVISÃO"
                        android:textColor="@color/texto_inativo"
                        android:textSize="8sp"
                        android:letterSpacing="0.08" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Em breve"
                        android:textColor="@color/texto_inativo"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="8dp" />

            <!-- Grelha de Categorias 2x2 (flex restante) -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvCategorias"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="3.5"
                android:overScrollMode="never"
                android:clipToPadding="false"
                android:paddingBottom="8dp" />

        </LinearLayout>

        <!-- Separador vertical invisível -->
        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="@color/divider" />

        <!-- ============================================= -->
        <!-- COLUNA DIREITA 48%                            -->
        <!-- ============================================= -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="48"
            android:orientation="vertical"
            android:padding="10dp">

            <!-- Área de destaque do documento (flex restante) -->
            <FrameLayout
                android:id="@+id/frameDestaque"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:background="@drawable/bg_destaque_card"
                android:clipToOutline="true">

                <ImageView
                    android:id="@+id/imgDestaque"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="fitCenter"
                    android:padding="4dp"
                    android:contentDescription="Documento em destaque" />

                <TextView
                    android:id="@+id/tvSemDocumento"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="Selecione um documento"
                    android:textColor="@color/texto_inativo"
                    android:textSize="18sp"
                    android:visibility="visible" />

                <!-- Indicador de página -->
                <TextView
                    android:id="@+id/tvPaginaIndicador"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="top|end"
                    android:layout_margin="12dp"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp"
                    android:background="@drawable/bg_nav_arrow"
                    android:textColor="@android:color/white"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.05"
                    android:visibility="gone" />

                <!-- Seta esquerda -->
                <ImageButton
                    android:id="@+id/btnPaginaAnterior"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_gravity="start|center_vertical"
                    android:layout_margin="12dp"
                    android:src="@drawable/ic_chevron_left"
                    app:tint="@android:color/white"
                    android:background="@drawable/bg_nav_arrow"
                    android:contentDescription="Página anterior"
                    android:visibility="gone" />

                <!-- Seta direita -->
                <ImageButton
                    android:id="@+id/btnPaginaSeguinte"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_gravity="end|center_vertical"
                    android:layout_margin="12dp"
                    android:src="@drawable/ic_chevron_right"
                    app:tint="@android:color/white"
                    android:background="@drawable/bg_nav_arrow"
                    android:contentDescription="Página seguinte"
                    android:visibility="gone" />
            </FrameLayout>

            <View android:layout_width="match_parent" android:layout_height="12dp" />

            <!-- Grelha de documentos -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvDocumentos"
                android:layout_width="match_parent"
                android:layout_height="140dp"
                android:overScrollMode="never"
                android:clipToPadding="false" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>