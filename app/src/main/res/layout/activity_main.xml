<?xml version="1.0" encoding="utf-8"?>
<!-- Substituímos tudo por ConstraintLayout: Otimização máxima para TVs de 75" -->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_principal"
    android:keepScreenOn="true"
    android:padding="10dp">

    <!-- Reduzido de 10% para 8% para dar mais altura ao vídeo e evitar corte no rodapé -->
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guide_top"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.08" />

    <!-- Linha Guia Vertical a 52% (Mantém a proporção áurea das colunas) -->
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guide_v_mid"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.52" />

    <!-- ==================== BARRA SUPERIOR (0% a 8%) ==================== -->
    <ImageView
        android:id="@+id/imgLogo"
        android:layout_width="wrap_content"
        android:layout_height="0dp"
        android:layout_marginTop="2dp"
        android:layout_marginBottom="2dp"
        android:layout_marginStart="14dp"
        android:adjustViewBounds="true"
        android:scaleType="fitStart"
        android:src="@drawable/ic_logo_mtbr_rect"
        android:contentDescription="@string/desc_logotipo"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/guide_top"
        app:layout_constraintStart_toStartOf="parent" />

    <LinearLayout
        android:id="@+id/llRelogio"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="end"
        android:layout_marginEnd="14dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/guide_top"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvHora"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/placeholder_hora"
            android:textColor="@color/texto_primario"
            android:textSize="28sp"
            android:textStyle="bold"
            android:lineSpacingMultiplier="1.0" />

        <TextView
            android:id="@+id/tvData"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/placeholder_data"
            android:textColor="@color/texto_inativo"
            android:textSize="11sp" />
    </LinearLayout>

    <View
        android:id="@+id/div_top"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="@color/divider"
        app:layout_constraintTop_toBottomOf="@id/guide_top"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Divisória Central Vertical -->
    <View
        android:id="@+id/div_v"
        android:layout_width="1dp"
        android:layout_height="0dp"
        android:background="@color/divider"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="10dp"
        app:layout_constraintTop_toBottomOf="@id/div_top"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toEndOf="@id/guide_v_mid"
        app:layout_constraintEnd_toStartOf="@id/guide_v_mid" />

    <!-- ==================== COLUNA ESQUERDA (0% a 52%) ==================== -->

    <!-- Player de vídeo estica-se aproveitando a subida da Guideline do topo -->
    <FrameLayout
        android:id="@+id/framePlayer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="10dp"
        android:layout_marginEnd="10dp"
        android:background="@drawable/bg_video_radius"
        android:clipToOutline="true"
        app:layout_constraintTop_toBottomOf="@id/div_top"
        app:layout_constraintBottom_toTopOf="@id/llIpma"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/guide_v_mid"
        app:layout_constraintVertical_weight="6">

        <androidx.media3.ui.PlayerView
            android:id="@+id/playerView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:use_controller="false"
            app:resize_mode="zoom" />
    </FrameLayout>

    <!-- Contentor IPMA integrado (sem caixa/fundo sólido) para um aspeto limpo -->
    <LinearLayout
        android:id="@+id/llIpma"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        android:layout_marginEnd="10dp"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        android:paddingTop="0dp"
        android:paddingBottom="0dp"
        app:layout_constraintTop_toBottomOf="@id/framePlayer"
        app:layout_constraintBottom_toTopOf="@id/rvCategorias"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/guide_v_mid">

        <!-- Título principal em sintonia com os restantes: ALL CAPS, 12sp e cinza -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/ipma_local"
            android:textColor="@color/texto_inativo"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textAllCaps="true"
            android:letterSpacing="0.05"
            android:layout_marginBottom="8dp" />

        <!-- Corpo: Hoje (Esq) | Amanhã (Dir) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:baselineAligned="false">

            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="12dp">
                <include layout="@layout/layout_ipma_card" android:id="@+id/cardHoje" />
            </FrameLayout>

            <!-- Separador Vertical subtil entre os dois dias -->
            <View
                android:layout_width="1dp"
                android:layout_height="32dp"
                android:layout_gravity="center_vertical"
                android:background="@color/borda_card" />

            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp">
                <include layout="@layout/layout_ipma_card" android:id="@+id/cardAmanha" />
            </FrameLayout>

        </LinearLayout>

        <!-- Fonte IPMA no canto inferior direito -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/ipma_fonte"
            android:textColor="@color/texto_inativo"
            android:textSize="9sp"
            android:gravity="end"
            android:layout_marginTop="6dp" />

    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvCategorias"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginEnd="10dp"
        android:overScrollMode="never"
        android:clipToPadding="false"
        android:paddingBottom="8dp"
        app:layout_constraintTop_toBottomOf="@id/llIpma"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/guide_v_mid"
        app:layout_constraintVertical_weight="3.5" />

    <!-- ==================== COLUNA DIREITA (52% a 100%) ==================== -->
    <FrameLayout
        android:id="@+id/frameDestaque"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="10dp"
        android:layout_marginStart="10dp"
        android:layout_marginBottom="12dp"
        android:background="@drawable/bg_destaque_card"
        android:clipToOutline="true"
        app:layout_constraintTop_toBottomOf="@id/div_top"
        app:layout_constraintBottom_toTopOf="@id/rvDocumentos"
        app:layout_constraintStart_toEndOf="@id/guide_v_mid"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/imgDestaque"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="fitCenter"
            android:padding="4dp"
            android:contentDescription="@string/desc_documento_destaque" />

        <TextView
            android:id="@+id/tvSemDocumento"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="@string/ui_selecione_documento"
            android:textColor="@color/texto_inativo"
            android:textSize="18sp"
            android:visibility="visible" />

        <TextView
            android:id="@+id/tvPaginaIndicador"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|end"
            android:layout_margin="12dp"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:background="@drawable/bg_nav_arrow"
            android:textColor="@android:color/white"
            android:textSize="14sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <ImageButton
            android:id="@+id/btnPaginaAnterior"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="start|center_vertical"
            android:layout_margin="12dp"
            android:src="@drawable/ic_chevron_left"
            app:tint="@android:color/white"
            android:background="@drawable/bg_nav_arrow"
            android:visibility="gone" />

        <ImageButton
            android:id="@+id/btnPaginaSeguinte"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="end|center_vertical"
            android:layout_margin="12dp"
            android:src="@drawable/ic_chevron_right"
            app:tint="@android:color/white"
            android:background="@drawable/bg_nav_arrow"
            android:visibility="gone" />
    </FrameLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvDocumentos"
        android:layout_width="0dp"
        android:layout_height="140dp"
        android:layout_marginStart="10dp"
        android:overScrollMode="never"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/frameDestaque"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toEndOf="@id/guide_v_mid"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>